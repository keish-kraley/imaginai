# Database
DATABASE_URL="postgresql://imaginai:imaginai@localhost:5432/imaginai?schema=public"

# NextAuth
AUTH_SECRET="change-me-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (NextAuth)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Google Cloud Platform
GCP_PROJECT_ID=""
GCP_LOCATION="us-central1"
# Paste the full service account JSON (as a single-line string) OR point
# GOOGLE_APPLICATION_CREDENTIALS to a file path mounted into the container.
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_APPLICATION_CREDENTIALS=""

# Vertex AI model IDs
VERTEX_IMAGE_MODEL="gemini-2.5-flash-image"
VERTEX_TEXT_MODEL="gemini-2.5-flash"

# Cloud Storage
GCS_BUCKET_NAME=""
GCS_SIGNED_URL_EXPIRATION_DAYS="7"

# Email (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ImaginAI <no-reply@astra-sa.com>"
ADMIN_EMAIL="ideias@astra-sa.com"
CONTACT_EMAIL="contato@astra-sa.com"

# Optional: SendGrid (alternative to SMTP)
SENDGRID_API_KEY=""

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Rate limiting (messages per minute per user)
CHAT_RATE_LIMIT_PER_MINUTE="30"
